# =============================================================================
# Memento — Environment Variables
# Copy to .env and fill in required values
# =============================================================================

# --- LLM Provider (required) ---
MEMENTO_LLM_BASE_URL=https://api.openai.com/v1
MEMENTO_LLM_MODEL=gpt-4o
MEMENTO_LLM_API_KEY=your-api-key-here          # REQUIRED — no default

# --- FalkorDB ---
MEMENTO_FALKORDB_HOST=localhost
MEMENTO_FALKORDB_PORT=6379

# --- Memory Settings ---
MEMENTO_CONFIDENCE_THRESHOLD=0.6
MEMENTO_SESSION_TIMEOUT=3600
MEMENTO_MAX_CONTEXT_TOKENS=4000
MEMENTO_MAX_MEMORIES_PER_QUERY=20

# --- Scheduling ---
MEMENTO_CONSOLIDATION_SCHEDULE=*/30 * * * *
MEMENTO_ANALYTICS_SCHEDULE=0 2 * * 0

# --- Server Ports ---
MEMENTO_API_PORT=8080
MEMENTO_MCP_PORT=8081

# --- Logging ---
MEMENTO_LOG_LEVEL=INFO

# --- Authentication (optional) ---
# MEMENTO_API_KEY=
# MEMENTO_MCP_TOKEN=

# --- Promotion ---
MEMENTO_ORG_PROMOTION_MIN_SESSIONS=2
